{
  "name": "@drocketxx/pm2me",
  "version": "1.1.11",
  "description": "PM2 Deployment and Management System — Web UI for PM2 process management",
  "type": "module",
  "main": "backend/app.js",
  "bin": {
    "pm2me": "./bin/pm2me.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "connect-history-api-fallback": "^2.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lowdb": "^7.0.1",
    "morgan": "^1.10.1",
    "pm2": "^6.0.14",
    "simple-git": "^3.32.3",
    "socket.io": "^4.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/drocketxx/PM2Me.git"
  },
  "homepage": "https://github.com/drocketxx/PM2Me",
  "keywords": [
    "pm2",
    "deploy",
    "management",
    "nginx",
    "web-ui"
  ],
  "author": "drocketxx",
  "license": "ISC",
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:concurrent": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "cd frontend && npm run build",
    "dev": "npm run build && cd backend && npm run dev",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "pw": "cd backend && node scripts/change-password.js",
    "start": "node bin/pm2me.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14"
  }
}